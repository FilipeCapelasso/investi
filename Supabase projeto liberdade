-- ═══════════════════════════════════════════════════════════════════════════
--  CONFERÊNCIA (rode logado no app, no SQL Editor use o painel Table Editor):
--
--    select name, invested, gross, tax, net, gain from public.v_investment_position;
--    select * from public.v_wallet_summary;
--
--  "invested" tem que bater EXATAMENTE com o card "Investido" da Carteira.
-- ═══════════════════════════════════════════════════════════════════════════
