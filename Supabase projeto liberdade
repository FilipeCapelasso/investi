-- ═══════════════════════════════════════════════════════════════════════════
--  PROJETO LIBERDADE — BANCO DE DADOS v2 (Supabase / PostgreSQL)
--
--  O que mudou em relação à v1:
--    1. Novos tipos de movimentação: dividendo, juros, taxa.
--    2. Colunas GERADAS: signed_amount e is_capital  → a regra do capital
--       investido passa a viver no BANCO, não no front-end.
--    3. TRIGGER que mantém investments.amount_invested sempre correto
--       (antes o front-end atualizava esse cache "na mão" e ele desalinhava).
--    4. VIEWS que calculam investido / bruto / IR / IOF / líquido / lucro
--       direto no PostgreSQL — o app confere os cards contra elas.
--    5. Tabela wallets (múltiplas carteiras) e investments.wallet_id.
--    6. Realtime ligado nas tabelas → outra aba/celular atualiza sozinho.
--
--  Rode o script INTEIRO no SQL Editor do Supabase (Run).
--  É idempotente e não destrói dados: pode rodar em cima da v1.
-- ═══════════════════════════════════════════════════════════════════════════

create extension if not exists "pgcrypto";

-- ─────────────────────────────────────────────────────────────
-- 0) Utilitário: updated_at automático
-- ─────────────────────────────────────────────────────────────
create or replace function public.touch_updated_at()
returns trigger language plpgsql as $$
begin
  new.updated_at = now();
  return new;
end;
$$;

