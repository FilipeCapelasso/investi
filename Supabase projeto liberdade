-- 6.1) Tipos de movimentação (agora com dividendo, juros e taxa)
alter table public.investment_contributions
  drop constraint if exists investment_contributions_movement_type_check;
alter table public.investment_contributions
  add constraint investment_contributions_movement_type_check
  check (movement_type in ('inicial','aporte','resgate','rolagem',
                           'rendimento','dividendo','juros','taxa','correcao'));

-- 6.2) Valor: sempre > 0, exceto 'correcao' (que pode ser negativa)
alter table public.investment_contributions
  drop constraint if exists investment_contributions_amount_check;
alter table public.investment_contributions
  add constraint investment_contributions_amount_check
  check (amount <> 0 and (amount > 0 or movement_type = 'correcao'));

-- 6.3) ══ A REGRA DE OURO, DENTRO DO BANCO ══
--   signed_amount → o valor com o sinal certo (resgate/taxa entram negativos)
--   is_capital    → se a linha mexe no CAPITAL INVESTIDO
--                   (inicial, aporte, rolagem, resgate = sim)
--                   (rendimento, dividendo, juros, taxa, correcao = NÃO: são lucro/custo)
do $$
begin
  if not exists (select 1 from information_schema.columns
                 where table_schema='public' and table_name='investment_contributions'
                   and column_name='signed_amount') then
    alter table public.investment_contributions
      add column signed_amount numeric(14,2)
      generated always as (
        case when movement_type in ('resgate','taxa') then -abs(amount)
             when movement_type = 'correcao'          then amount
             else abs(amount) end
      ) stored;
  end if;

  if not exists (select 1 from information_schema.columns
                 where table_schema='public' and table_name='investment_contributions'
                   and column_name='is_capital') then
    alter table public.investment_contributions
      add column is_capital boolean
      generated always as (movement_type in ('inicial','aporte','rolagem','resgate')) stored;
  end if;
end $$;

