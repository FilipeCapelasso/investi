-- ─────────────────────────────────────────────────────────────
-- 8) TRIGGERS updated_at
-- ─────────────────────────────────────────────────────────────
do $$
declare t text;
begin
  foreach t in array array['profiles','plan','plan_phases','wallets','investments','investment_contributions'] loop
    execute format('drop trigger if exists trg_touch_%1$s on public.%1$I;', t);
    execute format('create trigger trg_touch_%1$s before update on public.%1$I
                    for each row execute function public.touch_updated_at();', t);
  end loop;
end $$;

-- ─────────────────────────────────────────────────────────────
-- 9) TRIGGER: mantém investments.amount_invested SEMPRE correto
--    (Aplicação inicial + aportes + rolagens − resgates)
--    Nunca mais o front-end precisa escrever esse cache.
-- ─────────────────────────────────────────────────────────────
create or replace function public.recalc_investment_totals()
returns trigger language plpgsql security definer set search_path = public as $$
declare
  v_inv uuid := coalesce(new.investment_id, old.investment_id);
  v_old uuid := old.investment_id;
begin
  update public.investments i
     set amount_invested = coalesce((
           select sum(c.signed_amount)
             from public.investment_contributions c
            where c.investment_id = i.id and c.is_capital), 0)
   where i.id = v_inv;

  -- movimentação trocada de investimento? o antigo também é recalculado
  if v_old is not null and v_old <> v_inv then
    update public.investments i
       set amount_invested = coalesce((
             select sum(c.signed_amount)
               from public.investment_contributions c
              where c.investment_id = i.id and c.is_capital), 0)
     where i.id = v_old;
  end if;

  return coalesce(new, old);
end;
$$;

drop trigger if exists trg_recalc_totals on public.investment_contributions;
create trigger trg_recalc_totals
  after insert or update or delete on public.investment_contributions
  for each row execute function public.recalc_investment_totals();

-- Recalcula tudo agora (corrige qualquer valor que ficou "travado" na v1)
update public.investments i
   set amount_invested = coalesce((
         select sum(c.signed_amount)
           from public.investment_contributions c
          where c.investment_id = i.id and c.is_capital), 0);

-- ─────────────────────────────────────────────────────────────
-- 10) MOTOR DE CÁLCULO NO BANCO — IR, IOF e taxa a.a. por tipo
--     (espelha exatamente o motor do front-end)
-- ─────────────────────────────────────────────────────────────
create or replace function public.fn_ir_rate(days numeric)
returns numeric language sql immutable as $$
  select case when days <= 180 then 0.225
              when days <= 360 then 0.200
              when days <= 720 then 0.175
              else 0.150 end;
$$;

create or replace function public.fn_iof_rate(days numeric)
returns numeric language sql immutable as $$
  select case when days >= 30 or days < 0 then 0
              else (array[100,96,93,90,86,83,80,76,73,70,66,63,60,56,53,50,
                          46,43,40,36,33,30,26,23,20,16,13,10,6,3])
                   [floor(days)::int + 1] / 100.0 end;
$$;

-- Rentabilidade nominal esperada (% a.a.) conforme o tipo do ativo
create or replace function public.fn_annual_rate(
  kind text, return_rate numeric, ipca_rate numeric,
  selic_rate numeric, cdi_rate numeric, cdi_percent numeric)
returns numeric language sql immutable as $$
  select case kind
    when 'ipca'      then ((1 + coalesce(return_rate,6)/100) * (1 + coalesce(ipca_rate,4.5)/100) - 1) * 100
    when 'selic'     then coalesce(selic_rate,15)
    when 'prefixado' then coalesce(return_rate,10)
    when 'cdb'       then coalesce(cdi_rate,10.5) * coalesce(cdi_percent,100) / 100
    when 'lci'       then coalesce(cdi_rate,10.5) * coalesce(cdi_percent,100) / 100
    when 'caixinha'  then coalesce(cdi_rate,10.5) * coalesce(cdi_percent,100) / 100
    when 'fii'       then coalesce(return_rate,8)
    when 'etf'       then coalesce(return_rate,12)
    when 'acoes'     then coalesce(return_rate,12)
    when 'cripto'    then coalesce(return_rate,15)
    when 'poupanca'  then case when coalesce(selic_rate,10.5) > 8.5
                               then 0.7 * coalesce(selic_rate,10.5)
                               else (power(1.005,12) - 1) * 100 end
    else coalesce(return_rate,10)
  end;
$$;

-- Ativos isentos de IR
create or replace function public.fn_is_taxable(kind text)
returns boolean language sql immutable as $$
  select kind not in ('lci','fii','poupanca');
$$;

-- ─────────────────────────────────────────────────────────────
-- 11) VIEW: posição de cada investimento, calculada pelo PostgreSQL
--     Investido → Bruto → IR/IOF → Líquido → Lucro
-- ─────────────────────────────────────────────────────────────
create or replace view public.v_investment_position as
with cfg as (
  select i.id, i.user_id, i.name, i.kind, i.is_main, i.color, i.icon,
         public.fn_annual_rate(i.kind, i.return_rate, i.ipca_rate,
                               i.selic_rate, i.cdi_rate, i.cdi_percent) / 100.0 as rate,
         public.fn_is_taxable(i.kind) as taxable
    from public.investments i
   where i.user_id = auth.uid()
),
lots as (
  select c.id, c.investment_id, c.is_capital, c.signed_amount,
         greatest(extract(epoch from (now() - c.contribution_date::timestamptz)) / 86400.0, 0) as days
    from public.investment_contributions c
   where c.user_id = auth.uid()
),
calc as (
  select cfg.id as investment_id,
         -- capital investido: aplicação inicial + aportes + rolagens − resgates
         coalesce(sum(l.signed_amount) filter (where l.is_capital), 0) as invested,
         -- valor bruto: capital corrigido pela rentabilidade + proventos − taxas
         coalesce(sum(
           case when l.is_capital
                then l.signed_amount * power(1 + cfg.rate, l.days / 365.0)
                else l.signed_amount end), 0) as gross,
         coalesce(sum(
           case when l.is_capital and cfg.taxable
                then (l.signed_amount * power(1 + cfg.rate, l.days / 365.0) - l.signed_amount)
                     * public.fn_ir_rate(l.days)
                else 0 end), 0) as ir,
         coalesce(sum(
           case when l.is_capital
                then (l.signed_amount * power(1 + cfg.rate, l.days / 365.0) - l.signed_amount)
                     * public.fn_iof_rate(l.days)
                else 0 end), 0) as iof,
         coalesce(sum(l.signed_amount) filter (where not l.is_capital and l.signed_amount > 0), 0) as proventos,
         coalesce(sum(-l.signed_amount) filter (where not l.is_capital and l.signed_amount < 0), 0) as taxas,
         count(l.id) as movimentacoes
    from cfg left join lots l on l.investment_id = cfg.id
   group by cfg.id
)
select c.investment_id,
       cfg.user_id, cfg.name, cfg.kind, cfg.is_main, cfg.color, cfg.icon,
       round(cfg.rate * 100, 3)                      as annual_rate_pct,
       round(c.invested, 2)                          as invested,
       round(greatest(c.gross, 0), 2)                as gross,
       round(greatest(c.ir, 0), 2)                   as ir,
       round(greatest(c.iof, 0), 2)                  as iof,
       round(greatest(c.ir,0) + greatest(c.iof,0), 2) as tax,
       round(greatest(c.gross,0) - greatest(c.ir,0) - greatest(c.iof,0), 2) as net,
       round(greatest(c.gross,0) - c.invested, 2)    as gain,
       round(greatest(c.gross,0) - greatest(c.ir,0) - greatest(c.iof,0) - c.invested, 2) as net_gain,
       round(c.proventos, 2)                         as proventos,
       round(c.taxas, 2)                             as taxas,
       c.movimentacoes
  from calc c
  join cfg on cfg.id = c.investment_id;

-- ─────────────────────────────────────────────────────────────
-- 12) VIEW: resumo da carteira (o que alimenta os cards)
-- ─────────────────────────────────────────────────────────────
create or replace view public.v_wallet_summary as
select user_id,
       count(*)                          as investimentos,
       round(sum(invested), 2)           as invested,
       round(sum(gross), 2)              as gross,
       round(sum(tax), 2)                as tax,
       round(sum(net), 2)                as net,
       round(sum(gain), 2)               as gain,
       round(sum(net_gain), 2)           as net_gain,
       round(sum(proventos), 2)          as proventos
  from public.v_investment_position
 group by user_id;

-- ─────────────────────────────────────────────────────────────
-- 13) VIEW: aportes por mês (gráfico de disciplina)
-- ─────────────────────────────────────────────────────────────
create or replace view public.v_monthly_contributions as
select user_id,
       date_trunc('month', contribution_date)::date as mes,
       round(sum(amount) filter (where movement_type in ('inicial','aporte')), 2) as aportado,
       round(sum(signed_amount) filter (where is_capital), 2)                     as fluxo_capital,
       count(*) as movimentacoes
  from public.investment_contributions
 where user_id = auth.uid()
 group by 1, 2;

-- As views são consultadas com a permissão de quem chama (RLS aplicada)
do $$
begin
  execute 'alter view public.v_investment_position   set (security_invoker = on)';
  execute 'alter view public.v_wallet_summary        set (security_invoker = on)';
  execute 'alter view public.v_monthly_contributions set (security_invoker = on)';
exception when others then
  raise notice 'security_invoker indisponível nesta versão; as views já filtram por auth.uid().';
end $$;

grant select on public.v_investment_position, public.v_wallet_summary, public.v_monthly_contributions to authenticated;

-- ─────────────────────────────────────────────────────────────
-- 14) Perfil + carteira padrão no cadastro
-- ─────────────────────────────────────────────────────────────
create or replace function public.handle_new_user()
returns trigger language plpgsql security definer set search_path = public as $$
begin
  insert into public.profiles (id, full_name)
  values (new.id, coalesce(new.raw_user_meta_data->>'name', split_part(new.email,'@',1)))
  on conflict (id) do nothing;

  insert into public.wallets (user_id, name, is_default)
  values (new.id, 'Minha carteira', true)
  on conflict do nothing;

  return new;
end;
$$;
drop trigger if exists on_auth_user_created on auth.users;
create trigger on_auth_user_created
  after insert on auth.users
  for each row execute function public.handle_new_user();

